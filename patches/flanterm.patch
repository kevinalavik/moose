+static ALWAYS_INLINE uint32_t alpha_blend(uint32_t fg, uint32_t bg, uint8_t a) {
+    uint32_t ia = 255 - a;
+    uint32_t r = ((fg >> 16 & 0xFF) * a + (bg >> 16 & 0xFF) * ia) / 255;
+    uint32_t g = ((fg >> 8  & 0xFF) * a + (bg >> 8  & 0xFF) * ia) / 255;
+    uint32_t b = ((fg       & 0xFF) * a + (bg       & 0xFF) * ia) / 255;
+    return (r << 16) | (g << 8) | b;
+}
